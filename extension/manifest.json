{
  "manifest_version": 3,
  "name": "BrainSync",
  "description": "A clean focus session popup to enter mental flow.",
  "version": "1.0.0",
  "action": {
    "default_title": "BrainSync",
    "default_popup": "popup.html",
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
